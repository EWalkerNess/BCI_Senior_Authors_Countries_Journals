# SHARED PLOT FUNCTION: build dual-axis bar + line figure

build_dual_axis_plot <- function(data, x_col, title_text) {
  scale_factor <- max(data$Citations) / max(data$Papers)
  
  ggplot(data, aes(x = reorder(.data[[x_col]], -Papers))) +
    geom_bar(aes(y = Papers), stat = "identity", fill = "#2E5F7E", alpha = 0.95) +
    geom_line(aes(y = Citations / scale_factor, group = 1),
              color = "#5BB8F5", linewidth = 1.2) +
    geom_point(aes(y = Citations / scale_factor),
               color = "#000080", size = 3) +
    scale_x_discrete(name = x_col) +
    scale_y_continuous(
      name     = "Fractional Paper Count (Bar)",
      limits   = c(0, NA),
      breaks   = pretty(c(0, max(data$Papers)), n = 6),
      labels   = function(x) round(x, 1),
      sec.axis = sec_axis(
        ~ . * scale_factor,
        name   = "Total Citations (Line)",
        breaks = pretty(c(0, max(data$Citations)), n = 6),
        labels = function(x) round(x, 0)
      )
    ) +
    labs(
      title    = title_text,
      subtitle = "Calculated via Fractional Counting Analysis",
      x        = x_col
    ) +
    bci_theme()
}


