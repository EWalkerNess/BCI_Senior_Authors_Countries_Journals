# Format senior author name as F. M. Lastname
# ============================================================
# STEP 3: Format senior author name as F. M. Lastname
# Handles three formats found in combined WoS + Scopus data:
# Format A (WoS):    "Lastname, INITIALS"   e.g. "Nicolelis, MAL"
# Format B (Scopus): "Lastname I.I."        e.g. "Nicolelis M.A.L."
# Format C (Scopus): "Lastname Firstname"   e.g. "St Lawrence K.S."
# ============================================================
format_author_name <- function(name) {
  if (is.na(name) || nchar(trimws(name)) == 0) return(NA_character_)

  name <- trimws(name)

  # FORMAT A: WoS style — "Lastname, INITIALS" (comma present, no periods in initials)
  if (str_detect(name, ",")) {
    parts     <- str_split(name, ",", simplify = TRUE)
    last      <- str_to_title(trimws(parts[1]))
    first_raw <- trimws(parts[2])

    # Extract individual letters as initials
    initials     <- str_extract_all(first_raw, "[A-Za-z]")[[1]]
    initials_fmt <- paste0(toupper(initials), ".", collapse = " ")
    return(paste(initials_fmt, last))
  }

  # FORMAT B/C: Scopus style — "Lastname I." or "Lastname Firstname I.I."
  # Strategy: tokens split by space; last token that contains only
  # letters and periods is the initials block; everything before is the last name
  tokens <- str_split(name, "\\s+", simplify = TRUE)
  tokens <- tokens[nzchar(tokens)]

  if (length(tokens) == 1) return(str_to_title(tokens[1]))

  # Find which tokens are initials (contain periods or are single letters)
  is_initial_block <- str_detect(tokens, "^[A-Za-z][A-Za-z.\\-]*\\.$|^[A-Za-z]$")

  # Last name = all tokens that are NOT initial blocks, from the start
  last_tokens    <- tokens[!is_initial_block]
  initial_tokens <- tokens[is_initial_block]

  # If nothing detected as initials, fall back: last token = initials, rest = lastname
  if (length(initial_tokens) == 0) {
    initial_tokens <- tail(tokens, 1)
    last_tokens    <- head(tokens, -1)
  }

  last <- str_to_title(paste(last_tokens, collapse = " "))

  # Extract individual letters from all initial tokens
  all_initials <- str_extract_all(paste(initial_tokens, collapse = ""), "[A-Za-z]")[[1]]
  initials_fmt <- paste0(toupper(all_initials), ".", collapse = " ")

  paste(initials_fmt, last)
}

raw_data <- raw_data %>%
  mutate(Senior_Author_Formatted = map_chr(Senior_Author, format_author_name))

# Deduplicate: where the same person appears in both WoS and Scopus
# formats, keep only one version by matching on cleaned last name + first initial
raw_data <- raw_data %>%
  mutate(
    Author_Key = str_extract(Senior_Author_Formatted, "[A-Z]\\..+$") %>%
                 str_to_lower() %>%
                 str_remove_all("[^a-z]")
  )

# Calculate fractional paper count per row
# Each paper counts as 1 / number_of_authors for each author

raw_data <- raw_data %>%
  mutate(
    N_Authors        = map_int(str_split(`Author Names`, ";"),
                               ~ sum(nzchar(trimws(.x)))),
    Fractional_Count = 1 / N_Authors
  )

# Retrieve all author affiliation countries via OpenAlex API using DOI links
# All unique countries per paper are listed, semicolon-separated.
# Papers with no affiliation data are recorded as NA.

get_countries_from_doi <- function(doi) {
  if (is.na(doi) || nchar(trimws(doi)) == 0) return(NA_character_)
  
  # Clean DOI — strip URL prefix, keep just the DOI string
  doi_clean <- str_remove(doi, "https?://(dx\\.)?doi\\.org/")
  
  # Query OpenAlex works endpoint by DOI
  url <- paste0("https://api.openalex.org/works/https://doi.org/", doi_clean)
  
  tryCatch({
    response <- GET(url, add_headers("User-Agent" = "ThinkNeuro Research/1.0"))
    
    if (status_code(response) != 200) return(NA_character_)
    
    data <- fromJSON(content(response, as = "text", encoding = "UTF-8"),
                     flatten = TRUE)
    
    # Extract all author affiliations
    authorships <- data$authorships
    
    if (is.null(authorships) || length(authorships) == 0) return(NA_character_)
    
    # Pull country codes from institution affiliations
    countries <- authorships %>%
      unnest(cols = any_of("institutions"), keep_empty = TRUE) %>%
      pull(any_of("country_code")) %>%
      discard(is.na) %>%
      unique()
    
    if (length(countries) == 0) return(NA_character_)
    
    # Convert ISO country codes to full country names
    country_names <- countrycode::countrycode(
      countries,
      origin      = "iso2c",
      destination = "country.name",
      warn        = FALSE
    )
    
    paste(na.omit(country_names), collapse = "; ")
    
  }, error = function(e) NA_character_)
}

